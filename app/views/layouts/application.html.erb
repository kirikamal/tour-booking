<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " | Prasanna Tours" : "Prasanna Tours & Transport — Sydney Day Trips & Airport Transfers" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Trusted Sydney day tours, airport transfers and vehicle hire. 10+ years experience. Blue Mountains, Jervis Bay, Canberra & more.' %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">

    <!-- Heroicons via unpkg -->
    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="antialiased">

    <!-- ── Top Bar ── -->
    <div class="bg-[#0d1b2e] text-white text-sm py-2 px-4 hidden md:block">
      <div class="max-w-7xl mx-auto flex justify-between items-center">
        <div class="flex items-center gap-6">
          <a href="tel:+61423877645" class="flex items-center gap-1.5 hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            +61 423 877 645
          </a>
          <a href="mailto:info@prasannatoursandtransport.com.au" class="flex items-center gap-1.5 hover:text-amber-400 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@prasannatoursandtransport.com.au
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-gray-400">Follow us:</span>
          <a href="#" class="hover:text-amber-400 transition-colors">Facebook</a>
          <a href="https://wa.me/61423877645" target="_blank" class="hover:text-green-400 transition-colors">WhatsApp</a>
        </div>
      </div>
    </div>

    <!-- ── Main Navigation ── -->
    <header class="sticky top-0 z-40 bg-white shadow-md" data-controller="navbar">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex justify-between items-center h-16">

          <!-- Logo -->
          <a href="<%= root_path %>" class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-[#1e3a5f] rounded-lg flex items-center justify-center group-hover:bg-amber-500 transition-colors">
              <svg class="w-6 h-6 text-amber-400 group-hover:text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </div>
            <div>
              <div class="font-display font-bold text-[#0d1b2e] text-base leading-tight">Prasanna Tours</div>
              <div class="text-amber-500 text-xs font-semibold leading-tight">&amp; Transport</div>
            </div>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-7">
            <%= link_to "Home",    root_path,    class: "nav-link #{current_page?(root_path) ? 'active' : ''}" %>
            <%= link_to "About",   about_path,   class: "nav-link #{current_page?(about_path) ? 'active' : ''}" %>
            <%= link_to "Tours",   tours_path,   class: "nav-link #{current_page?(tours_path) ? 'active' : ''}" %>

            <!-- Booking Dropdown -->
            <div class="relative group">
              <button class="nav-link flex items-center gap-1">
                Booking
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div class="absolute top-full left-0 mt-2 w-52 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <%= link_to "Tour Booking",      new_bookings_tour_path,    class: "flex items-center gap-2 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-amber-50 hover:text-amber-600 rounded-t-xl" %>
                <%= link_to "Airport Transfer",  new_bookings_airport_path, class: "flex items-center gap-2 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
                <%= link_to "Hire a Vehicle",    new_bookings_vehicle_path, class: "flex items-center gap-2 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-amber-50 hover:text-amber-600 rounded-b-xl" %>
              </div>
            </div>

            <%= link_to "Gallery", gallery_path,  class: "nav-link #{current_page?(gallery_path) ? 'active' : ''}" %>
            <%= link_to "Reviews", reviews_path,  class: "nav-link #{current_page?(reviews_path) ? 'active' : ''}" %>
            <%= link_to "Contact", contact_path,  class: "nav-link #{current_page?(contact_path) ? 'active' : ''}" %>
          </nav>

          <!-- CTA + Mobile hamburger -->
          <div class="flex items-center gap-3">
            <%= link_to "Book Now", new_bookings_tour_path, class: "hidden sm:inline-block btn-primary text-sm py-2.5 px-5" %>

            <!-- Mobile hamburger -->
            <button class="lg:hidden p-2 rounded-md text-gray-700 hover:bg-gray-100" data-action="click->navbar#toggleMenu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path data-navbar-target="openIcon"  stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                <path data-navbar-target="closeIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="hidden"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div class="lg:hidden hidden bg-white border-t border-gray-100 px-4 pb-4" data-navbar-target="mobileMenu">
        <div class="flex flex-col gap-1 pt-3">
          <%= link_to "Home",             root_path,                 class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "About",            about_path,                class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Tours",            tours_path,                class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Tour Booking",     new_bookings_tour_path,    class: "block py-2.5 px-3 pl-6 rounded-lg text-gray-600 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Airport Transfer", new_bookings_airport_path, class: "block py-2.5 px-3 pl-6 rounded-lg text-gray-600 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Hire a Vehicle",   new_bookings_vehicle_path, class: "block py-2.5 px-3 pl-6 rounded-lg text-gray-600 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Gallery",          gallery_path,              class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Reviews",          reviews_path,              class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Contact",          contact_path,              class: "block py-2.5 px-3 rounded-lg font-semibold text-gray-700 hover:bg-amber-50 hover:text-amber-600" %>
          <%= link_to "Book Now",       new_bookings_tour_path,    class: "mt-2 btn-primary text-center" %>
        </div>
      </div>
    </header>

    <!-- ── Flash Messages ── -->
    <% if notice %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-7xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 flex items-center gap-2">
          <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      </div>
    <% end %>

    <!-- ── Page Content ── -->
    <main>
      <%= yield %>
    </main>

    <!-- ── Footer ── -->
    <footer class="bg-[#0d1b2e] text-white pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

          <!-- Brand -->
          <div class="lg:col-span-1">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-amber-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </div>
              <div>
                <div class="font-display font-bold text-white text-base leading-tight">Prasanna Tours</div>
                <div class="text-amber-400 text-xs font-semibold">&amp; Transport</div>
              </div>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">Your trusted travel partner in Sydney. Over 10 years of experience delivering unforgettable Australian adventures.</p>
            <div class="flex gap-3">
              <a href="#" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-amber-500 transition-colors text-gray-300 hover:text-white text-xs font-bold">f</a>
              <a href="https://wa.me/61423877645" target="_blank" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-green-500 transition-colors">
                <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="font-display font-bold text-white mb-4">Quick Links</h3>
            <ul class="space-y-2">
              <% [["Home", root_path], ["About Us", about_path], ["Tours", tours_path], ["Gallery", gallery_path], ["Reviews", reviews_path], ["Contact", contact_path]].each do |label, path| %>
                <li><%= link_to label, path, class: "text-gray-400 hover:text-amber-400 transition-colors text-sm" %></li>
              <% end %>
            </ul>
          </div>

          <!-- Bookings -->
          <div>
            <h3 class="font-display font-bold text-white mb-4">Our Services</h3>
            <ul class="space-y-2">
              <% [["Tour Packages", new_bookings_tour_path], ["Airport Transfers", new_bookings_airport_path], ["Vehicle Hire", new_bookings_vehicle_path]].each do |label, path| %>
                <li><%= link_to label, path, class: "text-gray-400 hover:text-amber-400 transition-colors text-sm" %></li>
              <% end %>
            </ul>
            <div class="mt-4 p-3 bg-amber-500/10 rounded-lg border border-amber-500/20">
              <p class="text-amber-400 text-xs font-semibold uppercase tracking-wide mb-1">Operating Hours</p>
              <p class="text-gray-300 text-sm">Mon – Sun: 6:00 AM – 9:00 PM</p>
            </div>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="font-display font-bold text-white mb-4">Contact Us</h3>
            <ul class="space-y-3 text-sm">
              <li class="flex items-start gap-2.5 text-gray-400">
                <svg class="w-4 h-4 text-amber-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Epping, NSW 2121, Australia
              </li>
              <li class="flex items-center gap-2.5">
                <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <a href="tel:+61423877645" class="text-gray-400 hover:text-amber-400 transition-colors">+61 423 877 645</a>
              </li>
              <li class="flex items-center gap-2.5">
                <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href="mailto:info@prasannatoursandtransport.com.au" class="text-gray-400 hover:text-amber-400 transition-colors">info@prasannatoursandtransport.com.au</a>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-gray-500">
          <p>&copy; <%= Date.today.year %> Prasanna Tours &amp; Transport. All rights reserved.</p>
          <p>Built with ❤️ in Sydney, Australia</p>
        </div>
      </div>
    </footer>

    <!-- ── Fixed Social Sidebar ── -->
    <div class="social-sidebar">
      <a href="tel:+61423877645" title="Call Us"
         class="bg-[#1e3a5f] hover:bg-amber-500 transition-colors"
         style="border-radius: 8px 0 0 0;">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      </a>
      <a href="mailto:info@prasannatoursandtransport.com.au" title="Email Us"
         class="bg-[#152b47] hover:bg-amber-500 transition-colors">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </a>
      <a href="https://wa.me/61423877645" target="_blank" title="WhatsApp"
         class="bg-green-600 hover:bg-green-500 transition-colors">
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <a href="#" title="Facebook"
         class="bg-blue-700 hover:bg-blue-600 transition-colors"
         style="border-radius: 0 0 0 8px;">
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>

  </body>
</html>

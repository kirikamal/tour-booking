<%# ── Hero Section ── %>
<section class="relative min-h-[85vh] flex items-center overflow-hidden">

  <%# Background photo %>
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1920&q=80"
         alt="Australian landscape" class="w-full h-full object-cover" loading="eager">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(13,27,46,0.92) 0%, rgba(30,58,95,0.80) 50%, rgba(21,43,71,0.75) 100%);"></div>
  </div>
  <div class="absolute -right-32 top-1/2 -translate-y-1/2 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
  <div class="absolute -left-20 bottom-0 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-24 relative z-10 w-full">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-amber-500/20 border border-amber-500/30 rounded-full px-4 py-1.5 mb-6">
        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span class="text-amber-300 text-sm font-semibold">100% Trusted Travel Agency · Sydney</span>
      </div>
      <h1 class="font-display text-white text-5xl sm:text-6xl font-extrabold leading-tight mb-6">
        Discover <span class="text-amber-400">Australia</span><br>Your Way
      </h1>
      <p class="text-gray-300 text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl">
        Day trips, airport transfers &amp; private vehicle hire from Sydney. Let us take you to the most breathtaking destinations in Australia — safely, comfortably, affordably.
      </p>
      <div class="flex flex-wrap gap-4">
        <%= link_to "Explore Tours", tours_path, class: "btn-primary text-base px-8 py-4" %>
        <%= link_to "Book Airport Transfer", new_bookings_airport_path, class: "btn-outline-white text-base px-8 py-4" %>
      </div>
      <div class="flex flex-wrap items-center gap-6 mt-10 pt-8 border-t border-white/10">
        <% [["Fully Licensed & Insured", true], ["Door-to-Door Service", true], ["Small Group Experiences", true]].each do |text, _| %>
          <div class="flex items-center gap-2 text-gray-300 text-sm">
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <%= text %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
  </div>
</section>

<%# ── Stats Bar ── %>
<section class="stats-bar py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <% [["10+","Years of Experience"],["2,000+","Happy Travellers"],["6+","Tour Destinations"],["95%","Satisfaction Rate"]].each do |num, label| %>
        <div class="py-2">
          <div class="font-display text-3xl font-extrabold text-amber-400"><%= num %></div>
          <div class="text-gray-300 text-sm mt-1"><%= label %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Quick Booking Bar ── %>
<section class="bg-amber-50 border-y border-amber-100 py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row gap-3 items-center justify-between">
      <p class="font-display font-bold text-[#0d1b2e] text-lg">Ready to explore? Pick your booking type:</p>
      <div class="flex flex-wrap gap-3">
        <%= link_to "🗺️  Book a Tour",      new_bookings_tour_path,    class: "btn-primary py-2.5 text-sm" %>
        <%= link_to "✈️  Airport Transfer", new_bookings_airport_path, class: "btn-secondary py-2.5 text-sm" %>
        <%= link_to "🚐  Hire a Vehicle",   new_bookings_vehicle_path, class: "bg-[#1e3a5f] text-white font-bold py-2.5 px-5 rounded-lg hover:bg-[#152b47] transition-colors text-sm" %>
      </div>
    </div>
  </div>
</section>

<%# ── Tour Packages ── %>
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <p class="section-subtitle">Day Trips from Sydney</p>
      <h2 class="section-title">Our Popular <span class="text-amber-500">Tour Packages</span></h2>
      <p class="text-gray-500 mt-3 max-w-xl mx-auto">Hand-picked one-day adventures departing from Sydney. All-inclusive pricing per person, door-to-door pickup available.</p>
    </div>
    <% if @tours.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @tours.each do |tour| %>
          <div class="card group">
            <div class="relative h-52 bg-gradient-to-br from-[#1e3a5f] to-[#0d1b2e] overflow-hidden">
              <% if tour.featured_image_url.present? %>
                <img src="<%= tour.featured_image_url %>" alt="<%= tour.name %>"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 inset-x-0 p-4">
                <span class="text-white/90 font-medium text-sm"><%= tour.duration.presence || "1 Day" %> · <%= tour.departure_time.presence || "Early Departure" %></span>
              </div>
              <div class="absolute top-3 right-3 bg-amber-500 text-[#0d1b2e] font-extrabold text-lg px-3 py-1 rounded-lg shadow-lg">
                <%= tour.price_display %><span class="text-xs font-normal">/pp</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-display font-bold text-[#0d1b2e] text-lg mb-2 group-hover:text-amber-600 transition-colors"><%= tour.name %></h3>
              <% if tour.description.present? %>
                <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2"><%= tour.description %></p>
              <% end %>
              <% if tour.pickup_location.present? %>
                <div class="flex items-center gap-1.5 text-gray-400 text-xs mb-4">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                  Pickup: <%= tour.pickup_location %>
                </div>
              <% end %>
              <div class="flex gap-2">
                <%= link_to "Details", tour_path(tour), class: "flex-1 text-center btn-secondary py-2 text-sm" %>
                <%= link_to "Book Now", new_bookings_tour_path(tour_id: tour.id), class: "flex-1 text-center btn-primary py-2 text-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="text-center mt-10"><%= link_to "View All Tours", tours_path, class: "btn-secondary" %></div>
    <% else %>
      <p class="text-center text-gray-400 py-12">Tour packages coming soon!</p>
    <% end %>
  </div>
</section>

<%# ── Why Choose Us ── %>
<section class="py-20 section-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="section-subtitle">Why Travel With Us</p>
        <h2 class="section-title mb-6">Your Comfort &amp; Safety<br>Is Our Priority</h2>
        <p class="text-gray-600 leading-relaxed mb-8">With over a decade of experience, we pride ourselves on delivering seamless, memorable Australian adventures. Our professional drivers know every road, shortcut and hidden gem.</p>
        <div class="space-y-4">
          <% [
            ["Professional & Licensed Drivers", "All drivers are fully licenced, background-checked and trained."],
            ["Modern Comfortable Vehicles", "Air-conditioned, well-maintained fleet from sedans to minibuses."],
            ["Local Expert Knowledge", "Born and raised in Sydney — we know the best spots and stories."],
            ["Flexible Easy Booking", "Online booking, instant confirmation, support via phone or WhatsApp."]
          ].each do |title, desc| %>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-[#0d1b2e] mb-0.5"><%= title %></h4>
                <p class="text-gray-500 text-sm"><%= desc %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <% [
          ["bg-amber-500","🗺️","Tour Packages","6 amazing day trips from Sydney"],
          ["bg-[#1e3a5f]","✈️","Airport Transfers","All Sydney-area airports covered"],
          ["bg-orange-500","🚐","Vehicle Hire","Sedan to minibus, any group size"],
          ["bg-emerald-600","⭐","5-Star Service","95% of travellers rate us excellent"]
        ].each do |bg, icon, title, desc| %>
          <div class="<%= bg %> rounded-2xl p-6 text-white">
            <div class="text-3xl mb-3"><%= icon %></div>
            <h4 class="font-display font-bold text-lg mb-1"><%= title %></h4>
            <p class="text-white/80 text-sm"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ── Services Dark Section ── %>
<section class="section-navy py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
    <p class="section-subtitle" style="color:#f59e0b;">Our Services</p>
    <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-white mb-4">Everything You Need for Your Journey</h2>
    <p class="text-gray-400 mb-10 max-w-xl mx-auto">From day tours to airport pickups, we've got Sydney travel covered.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
      <% [
        [new_bookings_tour_path,    "🗺️", "Tour Packages",    "Explore Canberra, Blue Mountains, Jervis Bay & more on unforgettable guided day trips.", "Book a Tour"],
        [new_bookings_airport_path, "✈️", "Airport Transfers","Reliable on-time pickups and drop-offs for Sydney Airport and beyond. 24/7 availability.", "Book Transfer"],
        [new_bookings_vehicle_path, "🚐", "Vehicle Hire",     "Hire a comfortable sedan, SUV or van for your group. Professional driver included.", "Hire a Vehicle"]
      ].each do |path, icon, title, desc, cta| %>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-7 hover:bg-white/10 transition-colors">
          <div class="text-4xl mb-4"><%= icon %></div>
          <h3 class="font-display font-bold text-white text-xl mb-3"><%= title %></h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-6"><%= desc %></p>
          <%= link_to cta + "", path, class: "text-amber-400 font-semibold text-sm hover:text-amber-300 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Testimonials ── %>
<% if @reviews.any? %>
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="section-subtitle">What Our Travellers Say</p>
        <h2 class="section-title">Real Stories, <span class="text-amber-500">Real Smiles</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @reviews.each do |review| %>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <div class="flex gap-1 mb-3">
              <% review.rating.times { %><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% } %>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-4 italic">"<%= review.body %>"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-[#1e3a5f] flex items-center justify-center text-white font-bold text-sm"><%= review.author_name.first.upcase %></div>
              <div>
                <p class="font-semibold text-[#0d1b2e] text-sm"><%= review.author_name %></p>
                <p class="text-amber-500 text-xs"><%= review.tour&.name.presence || "Verified Traveller" %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="text-center mt-8"><%= link_to "Read All Reviews", reviews_path, class: "btn-secondary" %></div>
    </div>
  </section>
<% end %>

<%# ── Final CTA ── %>
<section class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 50%, #b45309 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center relative z-10">
    <h2 class="font-display text-3xl sm:text-4xl font-extrabold text-[#0d1b2e] mb-4">Ready for Your Next Adventure?</h2>
    <p class="text-[#152b47] text-lg mb-8 max-w-xl mx-auto">Book your Sydney day trip today and create memories that last a lifetime.</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <%= link_to "Book a Tour Now", new_bookings_tour_path, class: "bg-[#0d1b2e] text-white font-bold px-8 py-4 rounded-lg hover:bg-[#152b47] transition-colors" %>
      <%= link_to "Contact Us", contact_path, class: "bg-white text-[#0d1b2e] font-bold px-8 py-4 rounded-lg hover:bg-gray-100 transition-colors" %>
    </div>
  </div>
</section>

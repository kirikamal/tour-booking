<% content_for :title, "Customer Reviews" %>

<div class="relative py-20 text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1920&q=80"
         alt="Happy travellers" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2e]/90 to-[#1e3a5f]/82"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <p class="section-subtitle" style="color:#f59e0b;">What Travellers Say</p>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-1">Customer Reviews</h1>
    <p class="text-gray-300 mt-3">Hundreds of happy travellers. Here are some of their stories.</p>
    <div class="flex items-center gap-2 mt-6">
      <div class="flex gap-1"><% 5.times { %><svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% } %></div>
      <span class="font-bold text-white text-lg">4.9</span><span class="text-gray-400">/ 5.0 average rating</span>
    </div>
  </div>
</div>

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <% if @reviews.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <% @reviews.each do |review| %>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100 flex flex-col">
            <div class="flex gap-1 mb-3">
              <% review.rating.times { %><svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% } %>
            </div>
            <p class="text-gray-700 leading-relaxed italic flex-1 mb-4">"<%= review.body %>"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
              <div class="w-10 h-10 rounded-full bg-[#1e3a5f] flex items-center justify-center text-white font-bold"><%= review.author_name.first.upcase %></div>
              <div>
                <p class="font-semibold text-[#0d1b2e]"><%= review.author_name %></p>
                <p class="text-amber-500 text-xs font-medium"><%= review.tour&.name.presence || "Verified Traveller" %></p>
              </div>
              <div class="ml-auto text-gray-400 text-xs"><%= review.created_at.strftime("%b %Y") %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 text-gray-400 mb-16">
        <p class="text-lg">No reviews yet — be the first!</p>
      </div>
    <% end %>

    <div class="max-w-2xl mx-auto">
      <div class="bg-[#0d1b2e] rounded-2xl p-8 text-white">
        <h2 class="font-display font-bold text-2xl mb-2">Share Your Experience</h2>
        <p class="text-gray-400 mb-6 text-sm">Travelled with us? We'd love to hear about your experience!</p>

        <%= form_with model: @review, url: reviews_create_path, method: :post, local: true, class: "space-y-5" do |f| %>
          <% if @review.errors.any? %>
            <div class="bg-red-900/30 border border-red-500/30 rounded-xl p-4">
              <ul class="space-y-1"><% @review.errors.full_messages.each do |msg| %><li class="text-red-300 text-sm"><%= msg %></li><% end %></ul>
            </div>
          <% end %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <%= f.label :author_name, "Your Name *", class: "block text-gray-300 text-sm font-semibold mb-1" %>
              <%= f.text_field :author_name, class: "form-input bg-white/10 border-white/20 text-white placeholder-gray-500", placeholder: "John Smith" %>
            </div>
            <div>
              <%= f.label :rating, "Rating *", class: "block text-gray-300 text-sm font-semibold mb-1" %>
              <%= f.select :rating, [["⭐ 1 - Poor",1],["⭐⭐ 2 - Fair",2],["⭐⭐⭐ 3 - Good",3],["⭐⭐⭐⭐ 4 - Great",4],["⭐⭐⭐⭐⭐ 5 - Excellent",5]], { prompt: "Select rating" }, class: "form-input bg-white/10 border-white/20 text-white" %>
            </div>
          </div>
          <div>
            <%= f.label :body, "Your Review *", class: "block text-gray-300 text-sm font-semibold mb-1" %>
            <%= f.text_area :body, class: "form-input bg-white/10 border-white/20 text-white placeholder-gray-500", rows: 4, placeholder: "Tell us about your experience..." %>
          </div>
          <%= f.submit "Submit Review", class: "btn-primary cursor-pointer" %>
          <p class="text-gray-500 text-xs">Reviews are moderated before appearing publicly.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>

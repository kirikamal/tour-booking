<% content_for :title, "Tour Packages" %>

<%# Page Header %>
<div class="relative py-20 text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=1920&q=80"
         alt="Australian tour destinations" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2e]/92 to-[#1e3a5f]/80"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <p class="section-subtitle" style="color:#f59e0b;">Day Trips from Sydney</p>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-1">Our Tour Packages</h1>
    <p class="text-gray-300 mt-3 text-lg max-w-2xl">Explore Australia's most stunning destinations with our expertly guided day tours. All prices per person, inclusive of transport.</p>
    <div class="flex items-center gap-2 mt-4 text-sm text-gray-400">
      <%= link_to "Home", root_path, class: "hover:text-amber-400 transition-colors" %>
      <span>/</span>
      <span class="text-amber-400">Tours</span>
    </div>
  </div>
</div>

<%# Tours Grid %>
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <% if @tours.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @tours.each do |tour| %>
          <div class="card group">
            <div class="relative h-56 bg-gradient-to-br from-[#1e3a5f] to-[#0d1b2e] overflow-hidden">
              <% if tour.featured_image_url.present? %>
                <img src="<%= tour.featured_image_url %>" alt="<%= tour.name %>"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-[#0d1b2e]/75 via-transparent to-transparent"></div>
              <div class="absolute bottom-3 left-4 text-white">
                <span class="text-sm font-medium drop-shadow"><%= tour.duration.presence || "1 Day" %> Excursion</span>
              </div>
              <div class="absolute top-3 right-3 bg-amber-500 text-[#0d1b2e] font-extrabold text-lg px-3 py-1.5 rounded-xl shadow-lg">
                <%= tour.price_display %><span class="text-xs font-normal"> /pp</span>
              </div>
            </div>

            <div class="p-5">
              <h2 class="font-display font-bold text-[#0d1b2e] text-xl mb-2 group-hover:text-amber-600 transition-colors">
                <%= tour.name %>
              </h2>

              <% if tour.description.present? %>
                <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-3"><%= tour.description %></p>
              <% end %>

              <div class="space-y-1.5 mb-5 text-sm text-gray-500">
                <% if tour.pickup_location.present? %>
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                    Pickup: <%= tour.pickup_location %>
                  </div>
                <% end %>
                <% if tour.departure_time.present? %>
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Departs <%= tour.departure_time %>
                  </div>
                <% end %>
                <% if tour.max_passengers.present? %>
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Max <%= tour.max_passengers %> passengers
                  </div>
                <% end %>
              </div>

              <div class="flex gap-2">
                <%= link_to "View Details", tour_path(tour), class: "flex-1 text-center btn-secondary py-2.5 text-sm" %>
                <%= link_to "Book Now", new_bookings_tour_path(tour_id: tour.id), class: "flex-1 text-center btn-primary py-2.5 text-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20 text-gray-400">
        <svg class="w-20 h-20 mx-auto mb-4 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        <h3 class="text-xl font-semibold text-gray-500 mb-2">Tours Coming Soon</h3>
        <p>We're preparing exciting new tour packages. <%= link_to "Contact us", contact_path, class: "text-amber-500 hover:underline" %> to find out more.</p>
      </div>
    <% end %>
  </div>
</section>

<%# Bottom CTA %>
<section class="bg-amber-50 border-t border-amber-100 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
    <h3 class="font-display font-bold text-[#0d1b2e] text-2xl mb-2">Can't find what you're looking for?</h3>
    <p class="text-gray-600 mb-5">Contact us and we'll arrange a custom tour just for your group.</p>
    <%= link_to "Get in Touch", contact_path, class: "btn-primary" %>
  </div>
</section>

<% content_for :title, @tour.name %>

<%# Hero %>
<div class="relative py-20 text-white overflow-hidden">
  <div class="absolute inset-0">
    <% if @tour.featured_image_url.present? %>
      <img src="<%= @tour.featured_image_url %>" alt="<%= @tour.name %>"
           class="w-full h-full object-cover" loading="eager">
    <% else %>
      <img src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1920&q=80"
           alt="<%= @tour.name %>" class="w-full h-full object-cover" loading="eager">
    <% end %>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2e]/92 to-[#1e3a5f]/75"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
      <%= link_to "Home", root_path, class: "hover:text-amber-400 transition-colors" %>
      <span>/</span>
      <%= link_to "Tours", tours_path, class: "hover:text-amber-400 transition-colors" %>
      <span>/</span>
      <span class="text-amber-400"><%= @tour.name %></span>
    </div>
    <div class="flex flex-col lg:flex-row gap-8 items-start justify-between">
      <div class="flex-1">
        <p class="section-subtitle" style="color:#f59e0b;"><%= @tour.duration.presence || "1 Day" %> Excursion</p>
        <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-1 mb-4"><%= @tour.name %></h1>
        <div class="flex flex-wrap gap-4 text-sm text-gray-300">
          <% if @tour.pickup_location.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              Pickup: <%= @tour.pickup_location %>
            </span>
          <% end %>
          <% if @tour.departure_time.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Departs <%= @tour.departure_time %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-6 text-[#0d1b2e] shadow-xl min-w-64">
        <div class="text-center mb-4">
          <span class="text-4xl font-extrabold text-amber-500"><%= @tour.price_display %></span>
          <span class="text-gray-500 text-sm"> per person</span>
        </div>
        <%= link_to "Book This Tour", new_bookings_tour_path(tour_id: @tour.id), class: "btn-primary w-full text-center block text-base" %>
        <p class="text-center text-gray-400 text-xs mt-3">Instant confirmation · Door-to-door service</p>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-14">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <%# Main content %>
    <div class="lg:col-span-2">
      <% if @tour.description.present? %>
        <div class="prose max-w-none mb-10">
          <h2 class="font-display font-bold text-[#0d1b2e] text-2xl mb-4">About This Tour</h2>
          <p class="text-gray-600 leading-relaxed text-base"><%= @tour.description %></p>
        </div>
      <% end %>

      <%# Tour details grid %>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
        <% [
          ["⏱️", "Duration", @tour.duration.presence || "1 Day"],
          ["🕐", "Departs", @tour.departure_time.presence || "Early AM"],
          ["👥", "Group Size", @tour.max_passengers ? "Up to #{@tour.max_passengers}" : "Small Group"],
          ["📍", "Pickup", @tour.pickup_location.presence || "Discuss on booking"]
        ].each do |icon, label, val| %>
          <div class="bg-amber-50 rounded-xl p-4 text-center border border-amber-100">
            <div class="text-2xl mb-1"><%= icon %></div>
            <div class="text-xs text-gray-500 font-medium uppercase tracking-wide"><%= label %></div>
            <div class="font-bold text-[#0d1b2e] text-sm mt-0.5"><%= val %></div>
          </div>
        <% end %>
      </div>

      <%# Reviews %>
      <% if @reviews.any? %>
        <div>
          <h2 class="font-display font-bold text-[#0d1b2e] text-2xl mb-5">What Travellers Say</h2>
          <div class="space-y-4">
            <% @reviews.each do |review| %>
              <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                <div class="flex gap-1 mb-2">
                  <% review.rating.times { %><svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% } %>
                </div>
                <p class="text-gray-600 text-sm italic mb-3">"<%= review.body %>"</p>
                <p class="text-[#0d1b2e] font-semibold text-sm">— <%= review.author_name %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Sidebar %>
    <div class="space-y-5">
      <%# Booking card %>
      <div class="bg-white rounded-2xl border-2 border-amber-200 p-6 shadow-sm sticky top-24">
        <h3 class="font-display font-bold text-[#0d1b2e] text-lg mb-1">Ready to Book?</h3>
        <p class="text-gray-500 text-sm mb-4">Secure your spot — small groups fill fast!</p>
        <div class="text-3xl font-extrabold text-amber-500 mb-4">
          <%= @tour.price_display %><span class="text-base text-gray-500 font-normal"> /person</span>
        </div>
        <%= link_to "Book This Tour", new_bookings_tour_path(tour_id: @tour.id), class: "btn-primary block text-center w-full mb-3" %>
        <a href="tel:+61423877645" class="block text-center text-[#1e3a5f] font-semibold text-sm hover:text-amber-500 transition-colors">
          📞 Call: +61 423 877 645
        </a>
      </div>

      <%# Includes %>
      <div class="bg-amber-50 rounded-2xl p-5 border border-amber-100">
        <h4 class="font-bold text-[#0d1b2e] mb-3">What's Included</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <% ["Door-to-door pickup & drop-off", "Air-conditioned vehicle", "Professional driver & guide", "All park entry fees (if applicable)"].each do |item| %>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <%= item %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <%# Related Tours %>
  <% if @related.any? %>
    <div class="mt-16 pt-10 border-t border-gray-100">
      <h2 class="font-display font-bold text-[#0d1b2e] text-2xl mb-6">You Might Also Like</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <% @related.each do |tour| %>
          <div class="card group">
            <div class="relative h-40 bg-gradient-to-br from-[#1e3a5f] to-[#0d1b2e] overflow-hidden">
              <% if tour.featured_image_url.present? %>
                <img src="<%= tour.featured_image_url %>" alt="<%= tour.name %>"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <% end %>
              <div class="absolute top-3 right-3 bg-amber-500 text-[#0d1b2e] font-bold text-sm px-2.5 py-1 rounded-lg shadow"><%= tour.price_display %>/pp</div>
            </div>
            <div class="p-4">
              <h3 class="font-bold text-[#0d1b2e] mb-3 group-hover:text-amber-600 transition-colors"><%= tour.name %></h3>
              <div class="flex gap-2">
                <%= link_to "Details", tour_path(tour), class: "flex-1 text-center btn-secondary py-1.5 text-sm" %>
                <%= link_to "Book", new_bookings_tour_path(tour_id: tour.id), class: "flex-1 text-center btn-primary py-1.5 text-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

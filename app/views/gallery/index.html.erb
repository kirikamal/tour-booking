<% content_for :title, "Gallery" %>

<div class="relative py-20 text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1920&q=80"
         alt="Australian landscapes gallery" class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-gradient-to-r from-[#0d1b2e]/88 to-[#1e3a5f]/78"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <p class="section-subtitle" style="color:#f59e0b;">Photo Gallery</p>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-1">Moments &amp; Memories</h1>
    <p class="text-gray-300 mt-3 max-w-xl">A glimpse into the incredible experiences we create every day — from mountain peaks to coastal shores.</p>
  </div>
</div>

<section class="py-14 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <% if @images.any? %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @images.each do |img| %>
          <div class="group relative aspect-square rounded-xl overflow-hidden bg-gray-100 cursor-pointer">
            <% if img.image.attached? %>
              <%= image_tag img.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-[#1e3a5f] to-[#0d1b2e] flex items-center justify-center">
                <svg class="w-12 h-12 text-white/20" fill="currentColor" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
              </div>
            <% end %>
            <% if img.caption.present? %>
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-3 opacity-0 group-hover:opacity-100 transition-opacity">
                <p class="text-white text-xs font-medium"><%= img.caption %></p>
              </div>
            <% end %>
            <% if img.category.present? %>
              <span class="absolute top-2 left-2 bg-amber-500 text-[#0d1b2e] text-xs font-bold px-2 py-0.5 rounded-full capitalize"><%= img.category %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# Placeholder gallery — real destination photos %>
      <%
        placeholder_images = [
          { url: "https://images.unsplash.com/photo-1489824904134-891ab64532f1?auto=format&fit=crop&w=600&q=80", label: "Blue Mountains", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=600&q=80", label: "Jervis Bay", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1524820197278-540916411e20?auto=format&fit=crop&w=600&q=80", label: "Canberra", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1519046904884-53103b34b206?auto=format&fit=crop&w=600&q=80", label: "Nelson Bay", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1540202404-a2f29016b523?auto=format&fit=crop&w=600&q=80", label: "Kiama Coast", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=600&q=80", label: "Snowy Mountains", cat: "tours" },
          { url: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=600&q=80", label: "Alpine Lakes", cat: "scenery" },
          { url: "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=600&q=80", label: "Mountain Roads", cat: "scenery" },
          { url: "https://images.unsplash.com/photo-1449965408869-eaa3f722e40d?auto=format&fit=crop&w=600&q=80", label: "Our Fleet", cat: "vehicles" }
        ]
      %>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <% placeholder_images.each do |ph| %>
          <div class="group relative aspect-square rounded-xl overflow-hidden cursor-pointer">
            <img src="<%= ph[:url] %>" alt="<%= ph[:label] %>"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute inset-x-0 bottom-0 p-3 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-white text-sm font-semibold drop-shadow"><%= ph[:label] %></p>
            </div>
            <span class="absolute top-2 left-2 bg-amber-500 text-[#0d1b2e] text-xs font-bold px-2 py-0.5 rounded-full capitalize"><%= ph[:cat] %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<section class="bg-amber-50 border-t border-amber-100 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
    <h3 class="font-display font-bold text-[#0d1b2e] text-2xl mb-2">Want to be in our gallery?</h3>
    <p class="text-gray-600 mb-5">Share your photos from your trip with us on social media or via WhatsApp!</p>
    <a href="https://wa.me/61423877645" target="_blank" class="btn-primary inline-block">Share Your Photos 📸</a>
  </div>
</section>
